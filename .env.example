SEARCH_API_KEY=replace-with-a-long-random-key
# Set true to allow localhost requests without Authorization when SEARCH_API_KEY is blank.
SEARCH_ALLOW_LOCAL_NO_AUTH=false
SEARCH_DEFAULT_LIMIT=50
SEARCH_REQUEST_TIMEOUT_MS=25000
SEARCH_ENABLE_BROWSER_FALLBACK=false
# SEARCH_BROWSER_TIMEOUT_MS=45000
# SEARCH_ENABLE_INTERACTIVE_CAPTCHA=false
# SEARCH_INTERACTIVE_CAPTCHA_TIMEOUT_MS=180000
# SEARCH_USER_AGENT=Mozilla/5.0 (compatible; SearchAPI/1.0; +https://your-domain.example)
# SEARCH_ALLOWED_ORIGINS=https://your-app.example
