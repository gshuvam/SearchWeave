{
  "name": "searchapi",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:python": "python -m unittest discover -s python/searchweave-py/tests -p \"test_*.py\"",
    "test:workspaces": "npm run test && npm run -w @searchweave/client test && npm run -w @searchweave/cli test",
    "build:workspaces": "npm run build && npm run -w @searchweave/client build && npm run -w @searchweave/cli build",
    "pack:check": "npm run -w @searchweave/client pack:check && npm run -w @searchweave/cli pack:check"
  },
  "dependencies": {
    "@sparticuz/chromium": "^123.0.0",
    "cheerio": "^1.2.0",
    "next": "16.2.4",
    "puppeteer-core": "^24.29.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
